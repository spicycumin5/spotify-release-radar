# Copy this file to `.env` (which is gitignored) and fill in real values.
# Astro CLI automatically loads `.env` into the scheduler/webserver containers.

# --- Spotify API ---
# Create an app at https://developer.spotify.com/dashboard
# Redirect URI must be: http://localhost:8888/callback
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Obtained once via `python scripts/spotify_auth_setup.py`
SPOTIFY_REFRESH_TOKEN=your-spotify-refresh-token

# --- Alerting ---
# Where both "new release" and "pipeline failure" emails are sent.
ALERT_EMAIL_TO=you@example.com

# --- SMTP (Gmail example) ---
# Use a Gmail "App Password", not your normal password:
# https://myaccount.google.com/apppasswords
AIRFLOW__EMAIL__EMAIL_BACKEND=airflow.utils.email.send_email_smtp
AIRFLOW__SMTP__SMTP_HOST=smtp.gmail.com
AIRFLOW__SMTP__SMTP_PORT=587
AIRFLOW__SMTP__SMTP_STARTTLS=True
AIRFLOW__SMTP__SMTP_SSL=False
AIRFLOW__SMTP__SMTP_MAIL_FROM=your-gmail-address@gmail.com
AIRFLOW__SMTP__SMTP_USER=your-gmail-address@gmail.com
AIRFLOW__SMTP__SMTP_PASSWORD=your-gmail-app-password

# --- Postgres (defaults match Astro CLI's local Postgres) ---
PGHOST=localhost
PGPORT=5432
PGDATABASE=postgres
PGUSER=postgres
PGPASSWORD=postgres
